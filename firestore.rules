rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || 
         (request.auth.token.email == "elionilsonp13.upal@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isEmployee() {
      return isAuthenticated() && getUserData().role == 'employee';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.role in ['admin', 'employee'] &&
             data.email is string &&
             data.uid == request.auth.uid;
    }

    function isValidReceipt(data) {
      return data.keys().hasAll(['type', 'transactionId', 'amount', 'status', 'uploadedBy', 'employeeId']) &&
             data.type in ['pix', 'lottery', 'credit_card'] &&
             data.amount is number &&
             data.status in ['Valid', 'Fraud', 'Incomplete', 'Divergent'] &&
             data.uploadedBy == request.auth.uid;
    }

    function isValidEmployee(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0;
    }

    function isValidReceiver(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'action', 'timestamp']) &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && isOwner(userId);
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    match /receipts/{receiptId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReceipt(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /receivers/{receiverId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidReceiver(request.resource.data);
      allow update: if isAdmin() && isValidReceiver(request.resource.data);
      allow delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidLog(request.resource.data);
      allow update: if false;
      allow delete: if false;
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidEmployee(request.resource.data);
      allow update: if isAdmin() && isValidEmployee(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
